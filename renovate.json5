{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    ":pinAllExceptPeerDependencies",
  ],
  labels: ["dependencies"],
  packageRules: [
    {
      matchManagers: ["pip"],
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
    },
    {
      matchManagers: ["npm"],
      matchDepTypes: ["devDependencies"],
      matchUpdateTypes: ["minor", "patch"],
      automerge: true,
    },
  ],
  rangeStrategy: "bump",
  lockFileMaintenance: {
    enabled: true,
    schedule: ["every weekend"],
  },
}
